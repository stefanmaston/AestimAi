{
  "installCommand": "npm install && npm install --prefix api",
  "rewrites": [
    {
      "source": "/api/news",
      "destination": "https://feisty-curiosity-production-609f.up.railway.app/api/news"
    },
    {
      "source": "/api/uci/:path*",
      "destination": "https://feisty-curiosity-production-609f.up.railway.app/api/uci/:path*"
    },
    {
      "source": "/m/:id",
      "destination": "/api/m/:id"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/papers/aestimai-uci-journal-article.pdf",
      "destination": "/AestimAi_UCI_Journal_Article.pdf"
    },
    {
      "source": "/legal/aestimai-user-license-agreement-v2026-06-11.pdf",
      "destination": "/AestimAi_User_License_Agreement.pdf"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",            "value": "DENY" },
        { "key": "Referrer-Policy",            "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
