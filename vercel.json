{
  "rewrites": [
    {
      "source": "/api/uci/:path*",
      "destination": "https://feisty-curiosity-production-609f.up.railway.app/api/uci/:path*"
    },
    {
      "source": "/api/news/:path*",
      "destination": "https://news-production-370c.up.railway.app/api/news/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",            "value": "DENY" },
        { "key": "Referrer-Policy",            "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
