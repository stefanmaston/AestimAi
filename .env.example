# ── AestimAi – miljövariabler ──────────────────────────────
# Kopiera till .env för lokal utveckling. Lägg aldrig riktiga nycklar i Git.
# Produktion (aestimai.org): Vercel → Project → Settings → Environment Variables

# ── Backend (Railway, uci-server.js m.fl.) ─────────────────
ANTHROPIC_API_KEY=
NEWS_API_KEY=

# ── Vercel serverless (api/*) ─────────────────────────────
# Publika (samma som i frontend – får exponeras)
SUPABASE_URL=https://vaxtylcqnscnflsucyiv.supabase.co
SUPABASE_ANON_KEY=sb_publishable_EJWkHcLuQmbEnwAGkaEANg_6rue2HsZ

# HEMLIG – endast server-side. Supabase → Project Settings → API → service_role.
# Används bl.a. av Pro-abonnemang, extra annonser, radera konto, bytesmarknad-kontakt.
SUPABASE_SERVICE_ROLE_KEY=

# E-post (Resend). Verifiera domänen aestimai.org (SPF/DKIM) på resend.com.
RESEND_API_KEY=
CONTACT_TO_EMAIL=stefan@maston.se
MAIL_FROM=AestimAi Bytesmarknad <bytesmarknad@aestimai.org>

# Bas-URL för SEO-sidor och sitemap.
SITE_URL=https://aestimai.org

# ── Stripe (dashboard.stripe.com → Developers) ───────────
# HEMLIG – Secret key (sk_test_… lokalt, sk_live_… i Vercel Production).
# Används av Pro-abonnemang, extra annonser och UCI Lab checkout.
STRIPE_SECRET_KEY=

# Webhook signing secret (whsec_…). Skapa endpoint i Stripe:
#   URL: https://aestimai.org/api/billing/webhook
#   Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=

# Valfria Price ID (price_…). Om tom skapas priser automatiskt vid checkout.
STRIPE_PRICE_PRO_MONTHLY=          # Pro €25/mån (api/billing/checkout.js)
STRIPE_PRICE_EXTRA_LISTING=        # Extra annons €1/st (api/market/checkout.js)

# UCI Lab – engångsköp (api/shop/checkout.js). Alla valfria.
STRIPE_PRICE_SHELLY_PRO_3EM=
STRIPE_PRICE_VICTRON_SMARTSHUNT=
STRIPE_PRICE_ACR122U_NFC=
STRIPE_PRICE_NTAG215_50PACK=
STRIPE_PRICE_RPI5_STARTER=
STRIPE_PRICE_RUUVITAG_4PACK=
STRIPE_PRICE_LEDGER_NANO_X=
STRIPE_PRICE_ARANET4_CO2=

# Publishable key (pk_test_… / pk_live_…) behövs inte i AestimAi – Checkout sker server-side.
